{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "language_models": {
    "lmstudio": {
      "api_url": "http://localhost:1234/api/v0",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "play_sound_when_agent_done": "always",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-3.1-flash-lite",
    },
    "model_parameters": [],
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "auto",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Carbonfox - blurred",
    "dark": "Carbonfox - blurred",
  },
  "format_on_save": "on",
  "languages": {
    "Python": {
      "language_servers": ["pyrefly", "ruff"], // "!basedpyright", "pathy", "ruff"],
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true,
      },
      "colorize_brackets": true,
    },
  },
  "lsp": {
    "pathy": {
      "settings": {
        "auto_download": true,
        "release_channel": "stable",
        "verify_checksum": true,
      },
    },
  },
}
